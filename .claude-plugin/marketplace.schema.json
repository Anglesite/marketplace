{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Anglesite/marketplace/.claude-plugin/marketplace.schema.json",
  "title": "Claude Code Plugin Marketplace",
  "description": "Schema for .claude-plugin/marketplace.json. Derived from https://code.claude.com/docs/en/plugin-marketplaces.md",
  "type": "object",
  "required": ["name", "plugins"],
  "additionalProperties": true,
  "properties": {
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "owner": { "$ref": "#/$defs/person" },
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "pluginRoot": { "type": "string" },
        "allowCrossMarketplaceDependenciesOn": {
          "type": "array",
          "items": { "type": "object" }
        }
      }
    },
    "plugins": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/plugin" }
    }
  },
  "$defs": {
    "person": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "url": { "type": "string", "format": "uri" }
      }
    },
    "plugin": {
      "type": "object",
      "required": ["name", "source"],
      "additionalProperties": true,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "version": { "type": "string" },
        "homepage": { "type": "string", "format": "uri" },
        "author": { "$ref": "#/$defs/person" },
        "source": { "$ref": "#/$defs/source" }
      }
    },
    "source": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1,
          "pattern": "^(\\./|\\.\\./|/)",
          "description": "Local path to plugin. Must start with './', '../', or '/'. Bare names like 'owner/repo' are not valid here — use a github source object instead."
        },
        { "$ref": "#/$defs/githubSource" },
        { "$ref": "#/$defs/urlSource" },
        { "$ref": "#/$defs/gitSubdirSource" },
        { "$ref": "#/$defs/npmSource" }
      ]
    },
    "githubSource": {
      "type": "object",
      "required": ["source", "repo"],
      "additionalProperties": false,
      "properties": {
        "source": { "const": "github" },
        "repo": {
          "type": "string",
          "pattern": "^[^/\\s]+/[^/\\s]+$",
          "description": "GitHub repository in 'owner/name' form"
        },
        "ref": { "type": "string" },
        "sha": { "type": "string" }
      }
    },
    "urlSource": {
      "type": "object",
      "required": ["source", "url"],
      "additionalProperties": false,
      "properties": {
        "source": { "const": "url" },
        "url": { "type": "string", "format": "uri" },
        "ref": { "type": "string" },
        "sha": { "type": "string" }
      }
    },
    "gitSubdirSource": {
      "type": "object",
      "required": ["source", "url", "path"],
      "additionalProperties": false,
      "properties": {
        "source": { "const": "git-subdir" },
        "url": { "type": "string", "format": "uri" },
        "path": { "type": "string" },
        "ref": { "type": "string" },
        "sha": { "type": "string" }
      }
    },
    "npmSource": {
      "type": "object",
      "required": ["source", "package"],
      "additionalProperties": false,
      "properties": {
        "source": { "const": "npm" },
        "package": { "type": "string" },
        "version": { "type": "string" },
        "registry": { "type": "string", "format": "uri" }
      }
    }
  }
}
